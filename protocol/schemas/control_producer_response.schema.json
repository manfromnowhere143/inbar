    "request_id": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Request Id",
      "type": "string"
    },
    "request_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Request Sha256",
      "type": "string"
    },
    "schema_version": {
      "const": "fieldtrue.control-producer-response.v1",
      "default": "fieldtrue.control-producer-response.v1",
      "title": "Schema Version",
      "type": "string"
