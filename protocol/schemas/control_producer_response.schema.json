          "const": 22,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Control Count"
    },
    "execution_commit": {
      "anyOf": [
        {
          "pattern": "^(?:[0-9a-f]{40}|[0-9a-f]{64})$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Execution Commit"
    },
    "execution_tree": {
      "anyOf": [
        {
          "pattern": "^(?:[0-9a-f]{40}|[0-9a-f]{64})$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Execution Tree"
    },
    "failure_code": {
      "anyOf": [
        {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Failure Code"
    },
    "published_path": {
      "anyOf": [
        {
          "const": ".local/admission-controls/control_suite_receipt.json",
          "type": "string"
