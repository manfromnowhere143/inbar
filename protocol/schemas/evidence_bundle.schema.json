{
  "$defs": {
    "ArtifactRef": {
      "additionalProperties": false,
      "properties": {
        "artifact_id": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
          "title": "Artifact Id",
          "type": "string"
        },
        "bytes": {
          "minimum": 0,
          "title": "Bytes",
          "type": "integer"
        },
        "clock_domain": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Clock Domain"
        },
        "license_ref": {
          "minLength": 1,
          "title": "License Ref",
          "type": "string"
        },
        "lineage_sha256": {
          "default": [],
          "items": {
            "pattern": "^[0-9a-f]{64}$",
            "type": "string"
          },
          "title": "Lineage Sha256",
          "type": "array"
        },
        "media_type": {
          "minLength": 1,
          "title": "Media Type",
          "type": "string"
        },
        "sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Sha256",
          "type": "string"
        },
        "source_authority": {
          "minLength": 1,
          "title": "Source Authority",
          "type": "string"
        },
        "uri": {
          "minLength": 1,
          "title": "Uri",
          "type": "string"
        }
      },
      "required": [
        "artifact_id",
        "uri",
        "sha256",
        "bytes",
        "media_type",
        "source_authority",
        "license_ref"
      ],
      "title": "ArtifactRef",
      "type": "object"
    },
    "EvidenceItem": {
      "additionalProperties": false,
      "properties": {
        "artifact": {
          "$ref": "#/$defs/ArtifactRef"
        },
        "description": {
          "minLength": 1,
          "title": "Description",
          "type": "string"
        },
        "evidence_id": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
          "title": "Evidence Id",
          "type": "string"
        },
        "modality": {
          "$ref": "#/$defs/Modality"
        },
        "observed_end": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Observed End"
        },
        "observed_start": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Observed Start"
        }
      },
      "required": [
        "evidence_id",
        "modality",
        "artifact",
        "description"
      ],
      "title": "EvidenceItem",
      "type": "object"
    },
    "Modality": {
      "enum": [
        "telemetry",
        "command_log",
        "event_log",
        "configuration",
        "procedure",
        "schematic",
        "image",
        "video",
        "audio",
        "nondestructive_evaluation",
        "simulation",
        "operator_note"
      ],
      "title": "Modality",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "context": {
      "additionalProperties": true,
      "title": "Context",
      "type": "object"
    },
    "evidence": {
      "items": {
        "$ref": "#/$defs/EvidenceItem"
      },
      "minItems": 1,
      "title": "Evidence",
      "type": "array"
    },
    "incident_id": {
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
      "title": "Incident Id",
      "type": "string"
    },
    "mission_id": {
      "minLength": 1,
      "title": "Mission Id",
      "type": "string"
    },
    "schema_version": {
      "const": "fieldtrue.evidence-bundle.v1",
      "default": "fieldtrue.evidence-bundle.v1",
      "title": "Schema Version",
      "type": "string"
    },
    "system_family": {
      "minLength": 1,
      "title": "System Family",
      "type": "string"
    },
    "system_id": {
      "minLength": 1,
      "title": "System Id",
      "type": "string"
    },
    "truth_commitment": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Truth Commitment",
      "type": "string"
    },
    "truth_commitment_scheme": {
      "const": "sha256-canonical-truth-with-256bit-nonce",
      "default": "sha256-canonical-truth-with-256bit-nonce",
      "title": "Truth Commitment Scheme",
      "type": "string"
    }
  },
  "required": [
    "incident_id",
    "system_family",
    "system_id",
    "mission_id",
    "evidence",
    "truth_commitment"
  ],
  "title": "EvidenceBundle",
  "type": "object"
}
