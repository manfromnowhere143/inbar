{
  "$defs": {
    "ArtifactBinding": {
      "additionalProperties": false,
      "properties": {
        "bytes": {
          "minimum": 0,
          "title": "Bytes",
          "type": "integer"
        },
        "media_type": {
          "minLength": 1,
          "title": "Media Type",
          "type": "string"
        },
        "path": {
          "minLength": 1,
          "title": "Path",
          "type": "string"
        },
        "sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Sha256",
          "type": "string"
        }
      },
      "required": [
        "path",
        "sha256",
        "bytes",
        "media_type"
      ],
      "title": "ArtifactBinding",
      "type": "object"
    },
    "AttestationSubjectKind": {
      "enum": [
        "source_rights",
        "physical_provenance",
        "mechanism_truth",
        "review",
        "diagnostic_execution",
        "recovery_execution",
        "settled_outcome",
        "protocol_review",
        "shortcut_baseline",
        "control_suite",
        "model_visible_projection",
        "resource_usage",
        "truth_custody",
        "comparator_registry",
        "candidate_registry",
        "evidence_sequence"
      ],
      "title": "AttestationSubjectKind",
      "type": "string"
    },
    "CandidateIncidentRoot": {
      "additionalProperties": false,
      "properties": {
        "discovered_at": {
          "format": "date-time",
          "title": "Discovered At",
          "type": "string"
        },
        "discovery_evidence": {
          "$ref": "#/$defs/ArtifactBinding"
        },
        "incident_id": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
          "title": "Incident Id",
          "type": "string"
        },
        "physicality": {
          "$ref": "#/$defs/Physicality"
        },
        "root_incident_group_id": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
          "title": "Root Incident Group Id",
          "type": "string"
        },
        "source_id": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
          "title": "Source Id",
          "type": "string"
        }
      },
      "required": [
        "incident_id",
        "root_incident_group_id",
        "source_id",
        "physicality",
        "discovered_at",
        "discovery_evidence"
      ],
      "title": "CandidateIncidentRoot",
      "type": "object"
    },
    "Physicality": {
      "enum": [
        "physical",
        "simulated",
        "synthetic",
        "hand_drawn"
      ],
      "title": "Physicality",
      "type": "string"
    },
    "SignedAttestation": {
      "additionalProperties": false,
      "properties": {
        "attestation_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Attestation Hash",
          "type": "string"
        },
        "attestation_id": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
          "title": "Attestation Id",
          "type": "string"
        },
        "issued_at": {
          "format": "date-time",
          "title": "Issued At",
          "type": "string"
        },
        "schema_version": {
          "const": "fieldtrue.signed-attestation.v1",
          "default": "fieldtrue.signed-attestation.v1",
          "title": "Schema Version",
          "type": "string"
        },
        "signature": {
          "pattern": "^[0-9a-f]{128}$",
          "title": "Signature",
          "type": "string"
        },
        "signer_id": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
          "title": "Signer Id",
          "type": "string"
        },
        "signer_public_key": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Signer Public Key",
          "type": "string"
        },
        "subject_kind": {
          "$ref": "#/$defs/AttestationSubjectKind"
        },
        "subject_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Subject Sha256",
          "type": "string"
        }
      },
      "required": [
        "attestation_id",
        "signer_id",
        "subject_kind",
        "subject_sha256",
        "issued_at",
        "signer_public_key",
        "attestation_hash",
        "signature"
      ],
      "title": "SignedAttestation",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "attestation": {
      "$ref": "#/$defs/SignedAttestation"
    },
    "candidates": {
      "items": {
        "$ref": "#/$defs/CandidateIncidentRoot"
      },
      "minItems": 1,
      "title": "Candidates",
      "type": "array"
    },
    "produced_at": {
      "format": "date-time",
      "title": "Produced At",
      "type": "string"
    },
    "registrar_id": {
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
      "title": "Registrar Id",
      "type": "string"
    },
    "registry_id": {
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
      "title": "Registry Id",
      "type": "string"
    },
    "schema_version": {
      "const": "fieldtrue.acquisition-candidate-registry.v1",
      "default": "fieldtrue.acquisition-candidate-registry.v1",
      "title": "Schema Version",
      "type": "string"
    }
  },
  "required": [
    "registry_id",
    "produced_at",
    "registrar_id",
    "candidates",
    "attestation"
  ],
  "title": "AcquisitionCandidateRegistry",
  "type": "object"
}
