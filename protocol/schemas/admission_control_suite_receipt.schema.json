{
  "$defs": {
    "AdmissionControlResult": {
      "additionalProperties": false,
      "properties": {
        "control_id": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
          "title": "Control Id",
          "type": "string"
        },
        "evidence": {
          "$ref": "#/$defs/ArtifactBinding"
        },
        "expected_failure_code": {
          "anyOf": [
            {
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Expected Failure Code"
        },
        "expected_gate_id": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
          "title": "Expected Gate Id",
          "type": "string"
        },
        "expected_verdict": {
          "enum": [
            "PASS_PILOT",
            "BLOCKED_ACQUISITION",
            "BLOCKED_RIGHTS",
            "INVALID",
            "KILL_CONSTRUCT"
          ],
          "title": "Expected Verdict",
          "type": "string"
        },
        "fixture_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Fixture Sha256",
          "type": "string"
        },
        "observed_failure_code": {
          "anyOf": [
            {
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Observed Failure Code"
        },
        "observed_gate_id": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
          "title": "Observed Gate Id",
          "type": "string"
        },
        "observed_verdict": {
          "enum": [
            "PASS_PILOT",
            "BLOCKED_ACQUISITION",
            "BLOCKED_RIGHTS",
            "INVALID",
            "KILL_CONSTRUCT"
          ],
          "title": "Observed Verdict",
          "type": "string"
        },
        "passed": {
          "title": "Passed",
          "type": "boolean"
        },
        "pytest_node_id": {
          "pattern": "^tests/unit/test_acquisition\\.py::test_[a-z0-9_]+$",
          "title": "Pytest Node Id",
          "type": "string"
        },
        "report_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Report Sha256",
          "type": "string"
        }
      },
      "required": [
        "control_id",
        "fixture_sha256",
        "report_sha256",
        "evidence",
        "pytest_node_id",
        "expected_verdict",
        "observed_verdict",
        "expected_gate_id",
        "observed_gate_id",
        "expected_failure_code",
        "observed_failure_code",
        "passed"
      ],
      "title": "AdmissionControlResult",
      "type": "object"
    },
    "ArtifactBinding": {
      "additionalProperties": false,
      "properties": {
        "bytes": {
          "minimum": 0,
          "title": "Bytes",
          "type": "integer"
        },
        "media_type": {
          "minLength": 1,
          "title": "Media Type",
          "type": "string"
        },
        "path": {
          "minLength": 1,
          "title": "Path",
          "type": "string"
        },
        "sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Sha256",
          "type": "string"
        }
      },
      "required": [
        "path",
        "sha256",
        "bytes",
        "media_type"
      ],
      "title": "ArtifactBinding",
      "type": "object"
    },
    "AttestationSubjectKind": {
      "enum": [
        "source_rights",
        "physical_provenance",
        "mechanism_truth",
        "review",
        "diagnostic_execution",
        "recovery_execution",
        "settled_outcome",
        "protocol_review",
        "shortcut_baseline",
        "control_suite",
        "model_visible_projection",
        "resource_usage",
        "truth_custody",
        "comparator_registry",
        "candidate_registry",
        "evidence_sequence",
        "admission_verifier_certificate"
      ],
      "title": "AttestationSubjectKind",
      "type": "string"
    },
    "SignedAttestation": {
      "additionalProperties": false,
      "properties": {
        "attestation_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Attestation Hash",
          "type": "string"
        },
        "attestation_id": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
          "title": "Attestation Id",
          "type": "string"
        },
        "issued_at": {
          "format": "date-time",
          "title": "Issued At",
          "type": "string"
        },
        "schema_version": {
          "const": "fieldtrue.signed-attestation.v1",
          "default": "fieldtrue.signed-attestation.v1",
          "title": "Schema Version",
          "type": "string"
        },
        "signature": {
          "pattern": "^[0-9a-f]{128}$",
          "title": "Signature",
          "type": "string"
        },
        "signer_id": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
          "title": "Signer Id",
          "type": "string"
        },
        "signer_public_key": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Signer Public Key",
          "type": "string"
        },
        "subject_kind": {
          "$ref": "#/$defs/AttestationSubjectKind"
        },
        "subject_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Subject Sha256",
          "type": "string"
        }
      },
      "required": [
        "attestation_id",
        "signer_id",
        "subject_kind",
        "subject_sha256",
        "issued_at",
        "signer_public_key",
        "attestation_hash",
        "signature"
      ],
      "title": "SignedAttestation",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "attestation": {
      "$ref": "#/$defs/SignedAttestation"
    },
    "control_test_git_blob": {
      "pattern": "^(?:[0-9a-f]{40}|[0-9a-f]{64})$",
      "title": "Control Test Git Blob",
      "type": "string"
    },
    "control_test_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Control Test Sha256",
      "type": "string"
    },
    "controls": {
      "items": {
        "$ref": "#/$defs/AdmissionControlResult"
      },
      "title": "Controls",
      "type": "array"
    },
    "dependency_lock_git_blob": {
      "pattern": "^(?:[0-9a-f]{40}|[0-9a-f]{64})$",
      "title": "Dependency Lock Git Blob",
      "type": "string"
    },
    "dependency_lock_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Dependency Lock Sha256",
      "type": "string"
    },
    "executed_at": {
      "format": "date-time",
      "title": "Executed At",
      "type": "string"
    },
    "execution_commit": {
      "pattern": "^(?:[0-9a-f]{40}|[0-9a-f]{64})$",
      "title": "Execution Commit",
      "type": "string"
    },
    "execution_manifest": {
      "$ref": "#/$defs/ArtifactBinding"
    },
    "execution_tree": {
      "pattern": "^(?:[0-9a-f]{40}|[0-9a-f]{64})$",
      "title": "Execution Tree",
      "type": "string"
    },
    "fixture_builder_git_blob": {
      "pattern": "^(?:[0-9a-f]{40}|[0-9a-f]{64})$",
      "title": "Fixture Builder Git Blob",
      "type": "string"
    },
    "fixture_builder_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Fixture Builder Sha256",
      "type": "string"
    },
    "generator_git_blob": {
      "pattern": "^(?:[0-9a-f]{40}|[0-9a-f]{64})$",
      "title": "Generator Git Blob",
      "type": "string"
    },
    "generator_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Generator Sha256",
      "type": "string"
    },
    "schema_version": {
      "const": "fieldtrue.admission-control-suite-receipt.v1",
      "default": "fieldtrue.admission-control-suite-receipt.v1",
      "title": "Schema Version",
      "type": "string"
    },
    "suite_id": {
      "const": "iter001-admission-controls-v1",
      "title": "Suite Id",
      "type": "string"
    },
    "validator_git_blob": {
      "pattern": "^(?:[0-9a-f]{40}|[0-9a-f]{64})$",
      "title": "Validator Git Blob",
      "type": "string"
    },
    "validator_source_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Validator Source Sha256",
      "type": "string"
    }
  },
  "required": [
    "suite_id",
    "validator_git_blob",
    "validator_source_sha256",
    "fixture_builder_git_blob",
    "fixture_builder_sha256",
    "control_test_git_blob",
    "control_test_sha256",
    "generator_git_blob",
    "generator_sha256",
    "dependency_lock_git_blob",
    "dependency_lock_sha256",
    "execution_commit",
    "execution_tree",
    "execution_manifest",
    "executed_at",
    "controls",
    "attestation"
  ],
  "title": "AdmissionControlSuiteReceipt",
  "type": "object"
}
