{
  "$defs": {
    "ArtifactRef": {
      "additionalProperties": false,
      "properties": {
        "artifact_id": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
          "title": "Artifact Id",
          "type": "string"
        },
        "bytes": {
          "minimum": 0,
          "title": "Bytes",
          "type": "integer"
        },
        "clock_domain": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Clock Domain"
        },
        "license_ref": {
          "minLength": 1,
          "title": "License Ref",
          "type": "string"
        },
        "lineage_sha256": {
          "default": [],
          "items": {
            "pattern": "^[0-9a-f]{64}$",
            "type": "string"
          },
          "title": "Lineage Sha256",
          "type": "array"
        },
        "media_type": {
          "minLength": 1,
          "title": "Media Type",
          "type": "string"
        },
        "sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Sha256",
          "type": "string"
        },
        "source_authority": {
          "minLength": 1,
          "title": "Source Authority",
          "type": "string"
        },
        "uri": {
          "minLength": 1,
          "title": "Uri",
          "type": "string"
        }
      },
      "required": [
        "artifact_id",
        "uri",
        "sha256",
        "bytes",
        "media_type",
        "source_authority",
        "license_ref"
      ],
      "title": "ArtifactRef",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "abstention_rule": {
      "additionalProperties": true,
      "title": "Abstention Rule",
      "type": "object"
    },
    "calibration_artifact": {
      "$ref": "#/$defs/ArtifactRef"
    },
    "detection_rule": {
      "additionalProperties": true,
      "title": "Detection Rule",
      "type": "object"
    },
    "lineage_sha256": {
      "items": {
        "pattern": "^[0-9a-f]{64}$",
        "type": "string"
      },
      "minItems": 1,
      "title": "Lineage Sha256",
      "type": "array"
    },
    "max_false_alarms_per_hour": {
      "minimum": 0.0,
      "title": "Max False Alarms Per Hour",
      "type": "number"
    },
    "max_latency_ms": {
      "exclusiveMinimum": 0.0,
      "title": "Max Latency Ms",
      "type": "number"
    },
    "max_memory_mb": {
      "exclusiveMinimum": 0.0,
      "title": "Max Memory Mb",
      "type": "number"
    },
    "mechanism_id": {
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
      "title": "Mechanism Id",
      "type": "string"
    },
    "monitor_id": {
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
      "title": "Monitor Id",
      "type": "string"
    },
    "validity_domain": {
      "additionalProperties": true,
      "title": "Validity Domain",
      "type": "object"
    }
  },
  "required": [
    "monitor_id",
    "mechanism_id",
    "validity_domain",
    "detection_rule",
    "abstention_rule",
    "calibration_artifact",
    "max_false_alarms_per_hour",
    "max_latency_ms",
    "max_memory_mb",
    "lineage_sha256"
  ],
  "title": "MonitorSpecification",
  "type": "object"
}
