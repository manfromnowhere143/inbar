{
  "$defs": {
    "ArtifactBinding": {
      "additionalProperties": false,
      "properties": {
        "bytes": {
          "minimum": 0,
          "title": "Bytes",
          "type": "integer"
        },
        "media_type": {
          "minLength": 1,
          "title": "Media Type",
          "type": "string"
        },
        "path": {
          "minLength": 1,
          "title": "Path",
          "type": "string"
        },
        "sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Sha256",
          "type": "string"
        }
      },
      "required": [
        "path",
        "sha256",
        "bytes",
        "media_type"
      ],
      "title": "ArtifactBinding",
      "type": "object"
    },
    "AttestationSubjectKind": {
      "enum": [
        "source_rights",
        "physical_provenance",
        "mechanism_truth",
        "review",
        "diagnostic_execution",
        "recovery_execution",
        "settled_outcome",
        "protocol_review",
        "shortcut_baseline",
        "control_suite",
        "model_visible_projection",
        "resource_usage",
        "truth_custody",
        "comparator_registry",
        "candidate_registry",
        "evidence_sequence"
      ],
      "title": "AttestationSubjectKind",
      "type": "string"
    },
    "ShortcutRuleResult": {
      "additionalProperties": false,
      "properties": {
        "evaluation": {
          "$ref": "#/$defs/ArtifactBinding"
        },
        "implementation": {
          "$ref": "#/$defs/ArtifactBinding"
        },
        "resolves_mechanism_without_action": {
          "title": "Resolves Mechanism Without Action",
          "type": "boolean"
        },
        "rule_id": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
          "title": "Rule Id",
          "type": "string"
        },
        "truth_access": {
          "title": "Truth Access",
          "type": "boolean"
        }
      },
      "required": [
        "rule_id",
        "implementation",
        "evaluation",
        "truth_access",
        "resolves_mechanism_without_action"
      ],
      "title": "ShortcutRuleResult",
      "type": "object"
    },
    "SignedAttestation": {
      "additionalProperties": false,
      "properties": {
        "attestation_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Attestation Hash",
          "type": "string"
        },
        "attestation_id": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
          "title": "Attestation Id",
          "type": "string"
        },
        "issued_at": {
          "format": "date-time",
          "title": "Issued At",
          "type": "string"
        },
        "schema_version": {
          "const": "fieldtrue.signed-attestation.v1",
          "default": "fieldtrue.signed-attestation.v1",
          "title": "Schema Version",
          "type": "string"
        },
        "signature": {
          "pattern": "^[0-9a-f]{128}$",
          "title": "Signature",
          "type": "string"
        },
        "signer_id": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
          "title": "Signer Id",
          "type": "string"
        },
        "signer_public_key": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Signer Public Key",
          "type": "string"
        },
        "subject_kind": {
          "$ref": "#/$defs/AttestationSubjectKind"
        },
        "subject_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Subject Sha256",
          "type": "string"
        }
      },
      "required": [
        "attestation_id",
        "signer_id",
        "subject_kind",
        "subject_sha256",
        "issued_at",
        "signer_public_key",
        "attestation_hash",
        "signature"
      ],
      "title": "SignedAttestation",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "attestation": {
      "$ref": "#/$defs/SignedAttestation"
    },
    "evaluated_at": {
      "format": "date-time",
      "title": "Evaluated At",
      "type": "string"
    },
    "incident_ids_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Incident Ids Sha256",
      "type": "string"
    },
    "report_id": {
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
      "title": "Report Id",
      "type": "string"
    },
    "results": {
      "items": {
        "$ref": "#/$defs/ShortcutRuleResult"
      },
      "title": "Results",
      "type": "array"
    },
    "schema_version": {
      "const": "fieldtrue.shortcut-baseline-report.v1",
      "default": "fieldtrue.shortcut-baseline-report.v1",
      "title": "Schema Version",
      "type": "string"
    },
    "statistician_id": {
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
      "title": "Statistician Id",
      "type": "string"
    }
  },
  "required": [
    "report_id",
    "incident_ids_sha256",
    "evaluated_at",
    "results",
    "statistician_id",
    "attestation"
  ],
  "title": "ShortcutBaselineReport",
  "type": "object"
}
