{
  "$defs": {
    "MechanismClassDefinition": {
      "additionalProperties": false,
      "description": "One exact known mechanism definition.\n\nThe prediction key is not stored in this model.  It is recomputed from exactly the six\nAmendment 001 fields plus the flat domain member.  The reserved ``unknown`` value is not a\nknown mechanism class.",
      "properties": {
        "canonical_name": {
          "minLength": 1,
          "title": "Canonical Name",
          "type": "string"
        },
        "causal_locus": {
          "minLength": 1,
          "title": "Causal Locus",
          "type": "string"
        },
        "definition": {
          "minLength": 1,
          "title": "Definition",
          "type": "string"
        },
        "directionality": {
          "minLength": 1,
          "title": "Directionality",
          "type": "string"
        },
        "failure_mode": {
          "minLength": 1,
          "title": "Failure Mode",
          "type": "string"
        },
        "schema_version": {
          "const": "inbar.iter001.mechanism-class.v1",
          "title": "Schema Version",
          "type": "string"
        },
        "temporal_signature": {
          "minLength": 1,
          "title": "Temporal Signature",
          "type": "string"
        }
      },
      "required": [
        "schema_version",
        "canonical_name",
        "causal_locus",
        "failure_mode",
        "temporal_signature",
        "directionality",
        "definition"
      ],
      "title": "MechanismClassDefinition",
      "type": "object"
    },
    "ShortcutAttestation": {
      "additionalProperties": false,
      "properties": {
        "kind": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
          "title": "Kind",
          "type": "string"
        },
        "schema_version": {
          "const": "inbar.iter001.shortcut-attestation.v1",
          "title": "Schema Version",
          "type": "string"
        },
        "signature": {
          "pattern": "^[0-9a-f]{128}$",
          "title": "Signature",
          "type": "string"
        },
        "signer_id": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
          "title": "Signer Id",
          "type": "string"
        },
        "signer_public_key": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Signer Public Key",
          "type": "string"
        },
        "subject_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Subject Sha256",
          "type": "string"
        }
      },
      "required": [
        "schema_version",
        "signer_id",
        "kind",
        "subject_sha256",
        "signer_public_key",
        "signature"
      ],
      "title": "ShortcutAttestation",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Known mechanism definitions signed by the declared ontology reviewer.",
  "properties": {
    "attestation": {
      "$ref": "#/$defs/ShortcutAttestation"
    },
    "classes": {
      "items": {
        "$ref": "#/$defs/MechanismClassDefinition"
      },
      "minItems": 1,
      "title": "Classes",
      "type": "array"
    },
    "committed_at": {
      "format": "date-time",
      "title": "Committed At",
      "type": "string"
    },
    "ontology_reviewer_id": {
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
      "title": "Ontology Reviewer Id",
      "type": "string"
    },
    "ontology_reviewer_independence_group_id": {
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
      "title": "Ontology Reviewer Independence Group Id",
      "type": "string"
    },
    "schema_version": {
      "const": "inbar.iter001.shortcut-mechanism-ontology.v1",
      "title": "Schema Version",
      "type": "string"
    }
  },
  "required": [
    "schema_version",
    "classes",
    "committed_at",
    "ontology_reviewer_id",
    "ontology_reviewer_independence_group_id",
    "attestation"
  ],
  "title": "SignedMechanismOntology",
  "type": "object"
}
