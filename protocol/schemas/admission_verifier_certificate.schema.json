{
  "$defs": {
    "AttestationSubjectKind": {
      "enum": [
        "source_rights",
        "physical_provenance",
        "mechanism_truth",
        "review",
        "diagnostic_execution",
        "recovery_execution",
        "settled_outcome",
        "protocol_review",
        "shortcut_baseline",
        "control_suite",
        "model_visible_projection",
        "resource_usage",
        "truth_custody",
        "comparator_registry",
        "candidate_registry",
        "evidence_sequence",
        "admission_verifier_certificate"
      ],
      "title": "AttestationSubjectKind",
      "type": "string"
    },
    "SignedAttestation": {
      "additionalProperties": false,
      "properties": {
        "attestation_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Attestation Hash",
          "type": "string"
        },
        "attestation_id": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
          "title": "Attestation Id",
          "type": "string"
        },
        "issued_at": {
          "format": "date-time",
          "title": "Issued At",
          "type": "string"
        },
        "schema_version": {
          "const": "fieldtrue.signed-attestation.v1",
          "default": "fieldtrue.signed-attestation.v1",
          "title": "Schema Version",
          "type": "string"
        },
        "signature": {
          "pattern": "^[0-9a-f]{128}$",
          "title": "Signature",
          "type": "string"
        },
        "signer_id": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
          "title": "Signer Id",
          "type": "string"
        },
        "signer_public_key": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Signer Public Key",
          "type": "string"
        },
        "subject_kind": {
          "$ref": "#/$defs/AttestationSubjectKind"
        },
        "subject_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Subject Sha256",
          "type": "string"
        }
      },
      "required": [
        "attestation_id",
        "signer_id",
        "subject_kind",
        "subject_sha256",
        "issued_at",
        "signer_public_key",
        "attestation_hash",
        "signature"
      ],
      "title": "SignedAttestation",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "certificate_id": {
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
      "title": "Certificate Id",
      "type": "string"
    },
    "control_suite_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Control Suite Sha256",
      "type": "string"
    },
    "dependency_lock_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Dependency Lock Sha256",
      "type": "string"
    },
    "expires_at": {
      "format": "date-time",
      "title": "Expires At",
      "type": "string"
    },
    "iteration_id": {
      "const": "iter001_physical_causal_evidence_acquisition",
      "default": "iter001_physical_causal_evidence_acquisition",
      "title": "Iteration Id",
      "type": "string"
    },
    "not_before": {
      "format": "date-time",
      "title": "Not Before",
      "type": "string"
    },
    "root_attestation": {
      "$ref": "#/$defs/SignedAttestation"
    },
    "schema_version": {
      "const": "fieldtrue.admission-verifier-certificate.v1",
      "default": "fieldtrue.admission-verifier-certificate.v1",
      "title": "Schema Version",
      "type": "string"
    },
    "validator_git_blob": {
      "pattern": "^(?:[0-9a-f]{40}|[0-9a-f]{64})$",
      "title": "Validator Git Blob",
      "type": "string"
    },
    "validator_source_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Validator Source Sha256",
      "type": "string"
    },
    "verifier_id": {
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
      "title": "Verifier Id",
      "type": "string"
    },
    "verifier_public_key": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Verifier Public Key",
      "type": "string"
    }
  },
  "required": [
    "certificate_id",
    "verifier_id",
    "verifier_public_key",
    "validator_git_blob",
    "validator_source_sha256",
    "control_suite_sha256",
    "dependency_lock_sha256",
    "not_before",
    "expires_at",
    "root_attestation"
  ],
  "title": "AdmissionVerifierCertificate",
  "type": "object"
}
