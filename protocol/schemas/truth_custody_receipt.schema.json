{
  "$defs": {
    "ArtifactBinding": {
      "additionalProperties": false,
      "properties": {
        "bytes": {
          "minimum": 0,
          "title": "Bytes",
          "type": "integer"
        },
        "media_type": {
          "minLength": 1,
          "title": "Media Type",
          "type": "string"
        },
        "path": {
          "minLength": 1,
          "title": "Path",
          "type": "string"
        },
        "sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Sha256",
          "type": "string"
        }
      },
      "required": [
        "path",
        "sha256",
        "bytes",
        "media_type"
      ],
      "title": "ArtifactBinding",
      "type": "object"
    },
    "AttestationSubjectKind": {
      "enum": [
        "source_rights",
        "physical_provenance",
        "mechanism_truth",
        "review",
        "diagnostic_execution",
        "recovery_execution",
        "settled_outcome",
        "protocol_review",
        "shortcut_baseline",
        "control_suite",
        "model_visible_projection",
        "resource_usage",
        "truth_custody",
        "comparator_registry",
        "candidate_registry",
        "evidence_sequence",
        "admission_verifier_certificate"
      ],
      "title": "AttestationSubjectKind",
      "type": "string"
    },
    "SignedAttestation": {
      "additionalProperties": false,
      "properties": {
        "attestation_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Attestation Hash",
          "type": "string"
        },
        "attestation_id": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
          "title": "Attestation Id",
          "type": "string"
        },
        "issued_at": {
          "format": "date-time",
          "title": "Issued At",
          "type": "string"
        },
        "schema_version": {
          "const": "fieldtrue.signed-attestation.v1",
          "default": "fieldtrue.signed-attestation.v1",
          "title": "Schema Version",
          "type": "string"
        },
        "signature": {
          "pattern": "^[0-9a-f]{128}$",
          "title": "Signature",
          "type": "string"
        },
        "signer_id": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
          "title": "Signer Id",
          "type": "string"
        },
        "signer_public_key": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Signer Public Key",
          "type": "string"
        },
        "subject_kind": {
          "$ref": "#/$defs/AttestationSubjectKind"
        },
        "subject_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Subject Sha256",
          "type": "string"
        }
      },
      "required": [
        "attestation_id",
        "signer_id",
        "subject_kind",
        "subject_sha256",
        "issued_at",
        "signer_public_key",
        "attestation_hash",
        "signature"
      ],
      "title": "SignedAttestation",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "access_log": {
      "$ref": "#/$defs/ArtifactBinding"
    },
    "attestation": {
      "$ref": "#/$defs/SignedAttestation"
    },
    "committed_at": {
      "format": "date-time",
      "title": "Committed At",
      "type": "string"
    },
    "custodian_id": {
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
      "title": "Custodian Id",
      "type": "string"
    },
    "custody_id": {
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
      "title": "Custody Id",
      "type": "string"
    },
    "incident_id": {
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
      "title": "Incident Id",
      "type": "string"
    },
    "schema_version": {
      "const": "fieldtrue.truth-custody-receipt.v1",
      "default": "fieldtrue.truth-custody-receipt.v1",
      "title": "Schema Version",
      "type": "string"
    },
    "truth_record_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Truth Record Sha256",
      "type": "string"
    },
    "unauthorized_access_detected": {
      "title": "Unauthorized Access Detected",
      "type": "boolean"
    },
    "unsealed_at": {
      "format": "date-time",
      "title": "Unsealed At",
      "type": "string"
    }
  },
  "required": [
    "custody_id",
    "incident_id",
    "truth_record_sha256",
    "custodian_id",
    "committed_at",
    "unsealed_at",
    "access_log",
    "unauthorized_access_detected",
    "attestation"
  ],
  "title": "TruthCustodyReceipt",
  "type": "object"
}
