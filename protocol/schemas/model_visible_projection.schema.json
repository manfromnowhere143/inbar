{
  "$defs": {
    "ArtifactBinding": {
      "additionalProperties": false,
      "properties": {
        "bytes": {
          "minimum": 0,
          "title": "Bytes",
          "type": "integer"
        },
        "media_type": {
          "minLength": 1,
          "title": "Media Type",
          "type": "string"
        },
        "path": {
          "minLength": 1,
          "title": "Path",
          "type": "string"
        },
        "sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Sha256",
          "type": "string"
        }
      },
      "required": [
        "path",
        "sha256",
        "bytes",
        "media_type"
      ],
      "title": "ArtifactBinding",
      "type": "object"
    },
    "AttestationSubjectKind": {
      "enum": [
        "source_rights",
        "physical_provenance",
        "mechanism_truth",
        "review",
        "diagnostic_execution",
        "recovery_execution",
        "settled_outcome",
        "protocol_review",
        "shortcut_baseline",
        "control_suite",
        "model_visible_projection",
        "resource_usage",
        "truth_custody",
        "comparator_registry",
        "candidate_registry",
        "evidence_sequence"
      ],
      "title": "AttestationSubjectKind",
      "type": "string"
    },
    "SignedAttestation": {
      "additionalProperties": false,
      "properties": {
        "attestation_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Attestation Hash",
          "type": "string"
        },
        "attestation_id": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
          "title": "Attestation Id",
          "type": "string"
        },
        "issued_at": {
          "format": "date-time",
          "title": "Issued At",
          "type": "string"
        },
        "schema_version": {
          "const": "fieldtrue.signed-attestation.v1",
          "default": "fieldtrue.signed-attestation.v1",
          "title": "Schema Version",
          "type": "string"
        },
        "signature": {
          "pattern": "^[0-9a-f]{128}$",
          "title": "Signature",
          "type": "string"
        },
        "signer_id": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
          "title": "Signer Id",
          "type": "string"
        },
        "signer_public_key": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Signer Public Key",
          "type": "string"
        },
        "subject_kind": {
          "$ref": "#/$defs/AttestationSubjectKind"
        },
        "subject_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Subject Sha256",
          "type": "string"
        }
      },
      "required": [
        "attestation_id",
        "signer_id",
        "subject_kind",
        "subject_sha256",
        "issued_at",
        "signer_public_key",
        "attestation_hash",
        "signature"
      ],
      "title": "SignedAttestation",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "attestation": {
      "$ref": "#/$defs/SignedAttestation"
    },
    "curator_id": {
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
      "title": "Curator Id",
      "type": "string"
    },
    "evidence_bundle_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Evidence Bundle Sha256",
      "type": "string"
    },
    "excluded_fields": {
      "items": {
        "type": "string"
      },
      "title": "Excluded Fields",
      "type": "array"
    },
    "incident_id": {
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
      "title": "Incident Id",
      "type": "string"
    },
    "leakage_detected": {
      "title": "Leakage Detected",
      "type": "boolean"
    },
    "leakage_scan": {
      "$ref": "#/$defs/ArtifactBinding"
    },
    "model_input_artifacts": {
      "items": {
        "$ref": "#/$defs/ArtifactBinding"
      },
      "minItems": 2,
      "title": "Model Input Artifacts",
      "type": "array"
    },
    "plane_separation_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Plane Separation Sha256",
      "type": "string"
    },
    "projected_at": {
      "format": "date-time",
      "title": "Projected At",
      "type": "string"
    },
    "projection_id": {
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
      "title": "Projection Id",
      "type": "string"
    },
    "projection_implementation": {
      "$ref": "#/$defs/ArtifactBinding"
    },
    "schema_version": {
      "const": "fieldtrue.model-visible-projection.v1",
      "default": "fieldtrue.model-visible-projection.v1",
      "title": "Schema Version",
      "type": "string"
    },
    "source_manifest_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Source Manifest Sha256",
      "type": "string"
    }
  },
  "required": [
    "projection_id",
    "incident_id",
    "source_manifest_sha256",
    "plane_separation_sha256",
    "evidence_bundle_sha256",
    "model_input_artifacts",
    "excluded_fields",
    "projection_implementation",
    "leakage_scan",
    "leakage_detected",
    "projected_at",
    "curator_id",
    "attestation"
  ],
  "title": "ModelVisibleProjection",
  "type": "object"
}
