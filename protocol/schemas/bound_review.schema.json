{
  "$defs": {
    "ArtifactBinding": {
      "additionalProperties": false,
      "properties": {
        "bytes": {
          "minimum": 0,
          "title": "Bytes",
          "type": "integer"
        },
        "media_type": {
          "minLength": 1,
          "title": "Media Type",
          "type": "string"
        },
        "path": {
          "minLength": 1,
          "title": "Path",
          "type": "string"
        },
        "sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Sha256",
          "type": "string"
        }
      },
      "required": [
        "path",
        "sha256",
        "bytes",
        "media_type"
      ],
      "title": "ArtifactBinding",
      "type": "object"
    },
    "AttestationSubjectKind": {
      "enum": [
        "source_rights",
        "physical_provenance",
        "mechanism_truth",
        "review",
        "diagnostic_execution",
        "recovery_execution",
        "settled_outcome",
        "protocol_review",
        "shortcut_baseline",
        "control_suite",
        "model_visible_projection",
        "resource_usage",
        "truth_custody",
        "comparator_registry",
        "candidate_registry",
        "evidence_sequence"
      ],
      "title": "AttestationSubjectKind",
      "type": "string"
    },
    "ReviewPurpose": {
      "enum": [
        "mechanism",
        "ambiguity",
        "safe_test",
        "recovery",
        "settled_outcome"
      ],
      "title": "ReviewPurpose",
      "type": "string"
    },
    "RoleKind": {
      "enum": [
        "source_steward",
        "rights_reviewer",
        "evidence_curator",
        "truth_producer",
        "mechanism_reviewer",
        "hypothesis_proposer",
        "test_proposer",
        "safety_reviewer",
        "test_selector",
        "test_executor",
        "recovery_proposer",
        "recovery_executor",
        "outcome_verifier",
        "statistician"
      ],
      "title": "RoleKind",
      "type": "string"
    },
    "SignedAttestation": {
      "additionalProperties": false,
      "properties": {
        "attestation_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Attestation Hash",
          "type": "string"
        },
        "attestation_id": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
          "title": "Attestation Id",
          "type": "string"
        },
        "issued_at": {
          "format": "date-time",
          "title": "Issued At",
          "type": "string"
        },
        "schema_version": {
          "const": "fieldtrue.signed-attestation.v1",
          "default": "fieldtrue.signed-attestation.v1",
          "title": "Schema Version",
          "type": "string"
        },
        "signature": {
          "pattern": "^[0-9a-f]{128}$",
          "title": "Signature",
          "type": "string"
        },
        "signer_id": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
          "title": "Signer Id",
          "type": "string"
        },
        "signer_public_key": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Signer Public Key",
          "type": "string"
        },
        "subject_kind": {
          "$ref": "#/$defs/AttestationSubjectKind"
        },
        "subject_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Subject Sha256",
          "type": "string"
        }
      },
      "required": [
        "attestation_id",
        "signer_id",
        "subject_kind",
        "subject_sha256",
        "issued_at",
        "signer_public_key",
        "attestation_hash",
        "signature"
      ],
      "title": "SignedAttestation",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "attestation": {
      "$ref": "#/$defs/SignedAttestation"
    },
    "evidence": {
      "items": {
        "$ref": "#/$defs/ArtifactBinding"
      },
      "minItems": 1,
      "title": "Evidence",
      "type": "array"
    },
    "producer_role": {
      "$ref": "#/$defs/RoleKind"
    },
    "purpose": {
      "$ref": "#/$defs/ReviewPurpose"
    },
    "review_id": {
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
      "title": "Review Id",
      "type": "string"
    },
    "reviewed_at": {
      "format": "date-time",
      "title": "Reviewed At",
      "type": "string"
    },
    "reviewer_role": {
      "$ref": "#/$defs/RoleKind"
    },
    "subject_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Subject Sha256",
      "type": "string"
    }
  },
  "required": [
    "review_id",
    "purpose",
    "subject_sha256",
    "producer_role",
    "reviewer_role",
    "reviewed_at",
    "evidence",
    "attestation"
  ],
  "title": "BoundReview",
  "type": "object"
}
