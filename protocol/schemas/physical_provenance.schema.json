{
  "$defs": {
    "ArtifactBinding": {
      "additionalProperties": false,
      "properties": {
        "bytes": {
          "minimum": 0,
          "title": "Bytes",
          "type": "integer"
        },
        "media_type": {
          "minLength": 1,
          "title": "Media Type",
          "type": "string"
        },
        "path": {
          "minLength": 1,
          "title": "Path",
          "type": "string"
        },
        "sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Sha256",
          "type": "string"
        }
      },
      "required": [
        "path",
        "sha256",
        "bytes",
        "media_type"
      ],
      "title": "ArtifactBinding",
      "type": "object"
    },
    "AttestationSubjectKind": {
      "enum": [
        "source_rights",
        "physical_provenance",
        "mechanism_truth",
        "review",
        "diagnostic_execution",
        "recovery_execution",
        "settled_outcome",
        "protocol_review",
        "shortcut_baseline",
        "control_suite",
        "model_visible_projection",
        "resource_usage",
        "truth_custody",
        "comparator_registry",
        "candidate_registry",
        "evidence_sequence",
        "admission_verifier_certificate"
      ],
      "title": "AttestationSubjectKind",
      "type": "string"
    },
    "SignedAttestation": {
      "additionalProperties": false,
      "properties": {
        "attestation_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Attestation Hash",
          "type": "string"
        },
        "attestation_id": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
          "title": "Attestation Id",
          "type": "string"
        },
        "issued_at": {
          "format": "date-time",
          "title": "Issued At",
          "type": "string"
        },
        "schema_version": {
          "const": "fieldtrue.signed-attestation.v1",
          "default": "fieldtrue.signed-attestation.v1",
          "title": "Schema Version",
          "type": "string"
        },
        "signature": {
          "pattern": "^[0-9a-f]{128}$",
          "title": "Signature",
          "type": "string"
        },
        "signer_id": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
          "title": "Signer Id",
          "type": "string"
        },
        "signer_public_key": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Signer Public Key",
          "type": "string"
        },
        "subject_kind": {
          "$ref": "#/$defs/AttestationSubjectKind"
        },
        "subject_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Subject Sha256",
          "type": "string"
        }
      },
      "required": [
        "attestation_id",
        "signer_id",
        "subject_kind",
        "subject_sha256",
        "issued_at",
        "signer_public_key",
        "attestation_hash",
        "signature"
      ],
      "title": "SignedAttestation",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "acquired_at": {
      "format": "date-time",
      "title": "Acquired At",
      "type": "string"
    },
    "acquisition_lineage_id": {
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
      "title": "Acquisition Lineage Id",
      "type": "string"
    },
    "acquisition_session_id": {
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
      "title": "Acquisition Session Id",
      "type": "string"
    },
    "attestation": {
      "$ref": "#/$defs/SignedAttestation"
    },
    "baseline_evidence": {
      "$ref": "#/$defs/ArtifactBinding"
    },
    "baseline_restored_before": {
      "title": "Baseline Restored Before",
      "type": "boolean"
    },
    "configuration_id": {
      "minLength": 1,
      "title": "Configuration Id",
      "type": "string"
    },
    "environment_id": {
      "minLength": 1,
      "title": "Environment Id",
      "type": "string"
    },
    "hardware_id": {
      "minLength": 1,
      "title": "Hardware Id",
      "type": "string"
    },
    "incident_id": {
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
      "title": "Incident Id",
      "type": "string"
    },
    "independence_group_id": {
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
      "title": "Independence Group Id",
      "type": "string"
    },
    "independently_initiated": {
      "title": "Independently Initiated",
      "type": "boolean"
    },
    "initiation_evidence": {
      "$ref": "#/$defs/ArtifactBinding"
    },
    "physical_capture": {
      "$ref": "#/$defs/ArtifactBinding"
    },
    "provenance_id": {
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
      "title": "Provenance Id",
      "type": "string"
    },
    "root_incident_group_id": {
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
      "title": "Root Incident Group Id",
      "type": "string"
    },
    "schema_version": {
      "const": "fieldtrue.physical-provenance.v1",
      "default": "fieldtrue.physical-provenance.v1",
      "title": "Schema Version",
      "type": "string"
    },
    "site_id": {
      "minLength": 1,
      "title": "Site Id",
      "type": "string"
    },
    "source_id": {
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
      "title": "Source Id",
      "type": "string"
    },
    "source_resource_id": {
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
      "title": "Source Resource Id",
      "type": "string"
    },
    "system_family": {
      "minLength": 1,
      "title": "System Family",
      "type": "string"
    }
  },
  "required": [
    "provenance_id",
    "incident_id",
    "root_incident_group_id",
    "acquisition_session_id",
    "independence_group_id",
    "acquisition_lineage_id",
    "source_id",
    "source_resource_id",
    "system_family",
    "hardware_id",
    "configuration_id",
    "environment_id",
    "site_id",
    "acquired_at",
    "independently_initiated",
    "baseline_restored_before",
    "initiation_evidence",
    "baseline_evidence",
    "physical_capture",
    "attestation"
  ],
  "title": "PhysicalProvenanceRecord",
  "type": "object"
}
