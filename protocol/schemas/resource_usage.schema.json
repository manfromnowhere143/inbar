{
  "$defs": {
    "ArtifactBinding": {
      "additionalProperties": false,
      "properties": {
        "bytes": {
          "minimum": 0,
          "title": "Bytes",
          "type": "integer"
        },
        "media_type": {
          "minLength": 1,
          "title": "Media Type",
          "type": "string"
        },
        "path": {
          "minLength": 1,
          "title": "Path",
          "type": "string"
        },
        "sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Sha256",
          "type": "string"
        }
      },
      "required": [
        "path",
        "sha256",
        "bytes",
        "media_type"
      ],
      "title": "ArtifactBinding",
      "type": "object"
    },
    "AttestationSubjectKind": {
      "enum": [
        "source_rights",
        "physical_provenance",
        "mechanism_truth",
        "review",
        "diagnostic_execution",
        "recovery_execution",
        "settled_outcome",
        "protocol_review",
        "shortcut_baseline",
        "control_suite",
        "model_visible_projection",
        "resource_usage",
        "truth_custody",
        "comparator_registry",
        "candidate_registry",
        "evidence_sequence",
        "admission_verifier_certificate"
      ],
      "title": "AttestationSubjectKind",
      "type": "string"
    },
    "SignedAttestation": {
      "additionalProperties": false,
      "properties": {
        "attestation_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Attestation Hash",
          "type": "string"
        },
        "attestation_id": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
          "title": "Attestation Id",
          "type": "string"
        },
        "issued_at": {
          "format": "date-time",
          "title": "Issued At",
          "type": "string"
        },
        "schema_version": {
          "const": "fieldtrue.signed-attestation.v1",
          "default": "fieldtrue.signed-attestation.v1",
          "title": "Schema Version",
          "type": "string"
        },
        "signature": {
          "pattern": "^[0-9a-f]{128}$",
          "title": "Signature",
          "type": "string"
        },
        "signer_id": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
          "title": "Signer Id",
          "type": "string"
        },
        "signer_public_key": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Signer Public Key",
          "type": "string"
        },
        "subject_kind": {
          "$ref": "#/$defs/AttestationSubjectKind"
        },
        "subject_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Subject Sha256",
          "type": "string"
        }
      },
      "required": [
        "attestation_id",
        "signer_id",
        "subject_kind",
        "subject_sha256",
        "issued_at",
        "signer_public_key",
        "attestation_hash",
        "signature"
      ],
      "title": "SignedAttestation",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "attestation": {
      "$ref": "#/$defs/SignedAttestation"
    },
    "cloud_jobs": {
      "minimum": 0,
      "title": "Cloud Jobs",
      "type": "integer"
    },
    "cost_usd": {
      "pattern": "^(0|[1-9][0-9]*)(\\.[0-9]{1,6})?$",
      "title": "Cost Usd",
      "type": "string"
    },
    "cpu_seconds": {
      "minimum": 0,
      "title": "Cpu Seconds",
      "type": "number"
    },
    "derived_bytes": {
      "minimum": 0,
      "title": "Derived Bytes",
      "type": "integer"
    },
    "downloaded_bytes": {
      "minimum": 0,
      "title": "Downloaded Bytes",
      "type": "integer"
    },
    "gpu_seconds": {
      "minimum": 0,
      "title": "Gpu Seconds",
      "type": "number"
    },
    "measured_at": {
      "format": "date-time",
      "title": "Measured At",
      "type": "string"
    },
    "measurement_artifact": {
      "$ref": "#/$defs/ArtifactBinding"
    },
    "measurement_method": {
      "minLength": 1,
      "title": "Measurement Method",
      "type": "string"
    },
    "measurer_id": {
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
      "title": "Measurer Id",
      "type": "string"
    },
    "paid_calls": {
      "minimum": 0,
      "title": "Paid Calls",
      "type": "integer"
    },
    "peak_memory_bytes": {
      "minimum": 0,
      "title": "Peak Memory Bytes",
      "type": "integer"
    },
    "peak_staged_bytes": {
      "minimum": 0,
      "title": "Peak Staged Bytes",
      "type": "integer"
    },
    "schema_version": {
      "const": "fieldtrue.resource-usage.v1",
      "default": "fieldtrue.resource-usage.v1",
      "title": "Schema Version",
      "type": "string"
    },
    "wall_seconds": {
      "minimum": 0,
      "title": "Wall Seconds",
      "type": "number"
    }
  },
  "required": [
    "cpu_seconds",
    "wall_seconds",
    "peak_memory_bytes",
    "downloaded_bytes",
    "peak_staged_bytes",
    "derived_bytes",
    "gpu_seconds",
    "cloud_jobs",
    "paid_calls",
    "cost_usd",
    "measured_at",
    "measurement_method",
    "measurement_artifact",
    "measurer_id",
    "attestation"
  ],
  "title": "ResourceUsage",
  "type": "object"
}
