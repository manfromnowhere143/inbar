{
  "$defs": {
    "RuntimeIdentity": {
      "additionalProperties": false,
      "allOf": [
        {
          "oneOf": [
            {
              "properties": {
                "dependency_closure_sha256": {
                  "type": "null"
                },
                "environment_provenance_sha256": {
                  "type": "null"
                },
                "fieldtrue_source_sha256": {
                  "type": "null"
                },
                "loaded_module_closure_sha256": {
                  "type": "null"
                },
                "provenance_state": {
                  "const": "legacy-unbound"
                },
                "python_interpreter_provenance_sha256": {
                  "type": "null"
                },
                "startup_provenance_sha256": {
                  "type": "null"
                }
              }
            },
            {
              "properties": {
                "dependency_closure_sha256": {
                  "pattern": "^[0-9a-f]{64}$",
                  "type": "string"
                },
                "environment_provenance_sha256": {
                  "pattern": "^[0-9a-f]{64}$",
                  "type": "string"
                },
                "fieldtrue_source_sha256": {
                  "pattern": "^[0-9a-f]{64}$",
                  "type": "string"
                },
                "loaded_module_closure_sha256": {
                  "pattern": "^[0-9a-f]{64}$",
                  "type": "string"
                },
                "provenance_state": {
                  "const": "observed-v1"
                },
                "python_interpreter_provenance_sha256": {
                  "pattern": "^[0-9a-f]{64}$",
                  "type": "string"
                },
                "startup_provenance_sha256": {
                  "pattern": "^[0-9a-f]{64}$",
                  "type": "string"
                }
              },
              "required": [
                "provenance_state",
                "python_interpreter_provenance_sha256",
                "startup_provenance_sha256",
                "environment_provenance_sha256",
                "fieldtrue_source_sha256",
                "loaded_module_closure_sha256",
                "dependency_closure_sha256"
              ]
            }
          ]
        }
      ],
      "description": "A receipt description, not proof against a compromised interpreter or OS TCB.\n\nHistorical receipts parse as ``legacy-unbound``. New confirmatory authority must call\n:meth:`require_observed_provenance` and refuse that legacy state. ``observed-v1`` binds\nwhat this already-running process could inspect; it does not elevate self-observation\ninto independent attestation.",
      "properties": {
        "command": {
          "items": {
            "type": "string"
          },
          "title": "Command",
          "type": "array"
        },
        "dependency_closure_sha256": {
          "anyOf": [
            {
              "pattern": "^[0-9a-f]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Dependency Closure Sha256"
        },
        "dirty_state_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Dirty State Hash",
          "type": "string"
        },
        "environment_provenance_sha256": {
          "anyOf": [
            {
              "pattern": "^[0-9a-f]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Environment Provenance Sha256"
        },
        "fieldtrue_source_sha256": {
          "anyOf": [
            {
              "pattern": "^[0-9a-f]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Fieldtrue Source Sha256"
        },
        "git_commit": {
          "pattern": "^(?:[0-9a-f]{40}|[0-9a-f]{64})$",
          "title": "Git Commit",
          "type": "string"
        },
        "git_tree": {
          "pattern": "^(?:[0-9a-f]{40}|[0-9a-f]{64})$",
          "title": "Git Tree",
          "type": "string"
        },
        "loaded_module_closure_sha256": {
          "anyOf": [
            {
              "pattern": "^[0-9a-f]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Loaded Module Closure Sha256"
        },
        "lockfile_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Lockfile Hash",
          "type": "string"
        },
        "platform": {
          "title": "Platform",
          "type": "string"
        },
        "provenance_state": {
          "default": "legacy-unbound",
          "enum": [
            "legacy-unbound",
            "observed-v1"
          ],
          "title": "Provenance State",
          "type": "string"
        },
        "python_interpreter_provenance_sha256": {
          "anyOf": [
            {
              "pattern": "^[0-9a-f]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Python Interpreter Provenance Sha256"
        },
        "python_version": {
          "title": "Python Version",
          "type": "string"
        },
        "repository_dirty": {
          "title": "Repository Dirty",
          "type": "boolean"
        },
        "startup_provenance_sha256": {
          "anyOf": [
            {
              "pattern": "^[0-9a-f]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Startup Provenance Sha256"
        }
      },
      "required": [
        "git_commit",
        "git_tree",
        "repository_dirty",
        "dirty_state_hash",
        "lockfile_hash",
        "python_version",
        "platform",
        "command"
      ],
      "title": "RuntimeIdentity",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "approval_receipt_hash": {
      "anyOf": [
        {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Approval Receipt Hash"
    },
    "event_hash": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Event Hash",
      "type": "string"
    },
    "event_type": {
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
      "title": "Event Type",
      "type": "string"
    },
    "payload": {
      "additionalProperties": true,
      "title": "Payload",
      "type": "object"
    },
    "payload_hash": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Payload Hash",
      "type": "string"
    },
    "previous_event_hash": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Previous Event Hash",
      "type": "string"
    },
    "run_id": {
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
      "title": "Run Id",
      "type": "string"
    },
    "runtime": {
      "$ref": "#/$defs/RuntimeIdentity"
    },
    "schema_version": {
      "const": "fieldtrue.ledger-event.v1",
      "default": "fieldtrue.ledger-event.v1",
      "title": "Schema Version",
      "type": "string"
    },
    "sequence": {
      "minimum": 0,
      "title": "Sequence",
      "type": "integer"
    },
    "signature": {
      "pattern": "^[0-9a-f]{128}$",
      "title": "Signature",
      "type": "string"
    },
    "signer_public_key": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Signer Public Key",
      "type": "string"
    },
    "timestamp": {
      "format": "date-time",
      "title": "Timestamp",
      "type": "string"
    }
  },
  "required": [
    "sequence",
    "timestamp",
    "run_id",
    "event_type",
    "payload",
    "payload_hash",
    "previous_event_hash",
    "runtime",
    "signer_public_key",
    "event_hash",
    "signature"
  ],
  "title": "LedgerEvent",
  "type": "object"
}
