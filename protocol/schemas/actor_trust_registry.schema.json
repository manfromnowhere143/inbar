{
  "$defs": {
    "ArtifactBinding": {
      "additionalProperties": false,
      "properties": {
        "bytes": {
          "minimum": 0,
          "title": "Bytes",
          "type": "integer"
        },
        "media_type": {
          "minLength": 1,
          "title": "Media Type",
          "type": "string"
        },
        "path": {
          "minLength": 1,
          "title": "Path",
          "type": "string"
        },
        "sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Sha256",
          "type": "string"
        }
      },
      "required": [
        "path",
        "sha256",
        "bytes",
        "media_type"
      ],
      "title": "ArtifactBinding",
      "type": "object"
    },
    "RoleKind": {
      "enum": [
        "source_steward",
        "rights_reviewer",
        "evidence_curator",
        "truth_producer",
        "mechanism_reviewer",
        "hypothesis_proposer",
        "test_proposer",
        "safety_reviewer",
        "test_selector",
        "test_executor",
        "recovery_proposer",
        "recovery_executor",
        "outcome_verifier",
        "statistician"
      ],
      "title": "RoleKind",
      "type": "string"
    },
    "TrustedActor": {
      "additionalProperties": false,
      "properties": {
        "actor_id": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
          "title": "Actor Id",
          "type": "string"
        },
        "authorized_roles": {
          "items": {
            "$ref": "#/$defs/RoleKind"
          },
          "minItems": 1,
          "title": "Authorized Roles",
          "type": "array"
        },
        "independence_group_id": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
          "title": "Independence Group Id",
          "type": "string"
        },
        "mandate": {
          "$ref": "#/$defs/ArtifactBinding"
        },
        "public_key": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Public Key",
          "type": "string"
        }
      },
      "required": [
        "actor_id",
        "independence_group_id",
        "public_key",
        "authorized_roles",
        "mandate"
      ],
      "title": "TrustedActor",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "actors": {
      "items": {
        "$ref": "#/$defs/TrustedActor"
      },
      "minItems": 1,
      "title": "Actors",
      "type": "array"
    },
    "issued_at": {
      "format": "date-time",
      "title": "Issued At",
      "type": "string"
    },
    "iteration_id": {
      "const": "iter001_physical_causal_evidence_acquisition",
      "title": "Iteration Id",
      "type": "string"
    },
    "registry_hash": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Registry Hash",
      "type": "string"
    },
    "registry_id": {
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
      "title": "Registry Id",
      "type": "string"
    },
    "schema_version": {
      "const": "fieldtrue.actor-trust-registry.v1",
      "default": "fieldtrue.actor-trust-registry.v1",
      "title": "Schema Version",
      "type": "string"
    },
    "signature": {
      "pattern": "^[0-9a-f]{128}$",
      "title": "Signature",
      "type": "string"
    },
    "signer_public_key": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Signer Public Key",
      "type": "string"
    }
  },
  "required": [
    "registry_id",
    "iteration_id",
    "issued_at",
    "actors",
    "signer_public_key",
    "registry_hash",
    "signature"
  ],
  "title": "ActorTrustRegistry",
  "type": "object"
}
