{
  "$defs": {
    "AttestationSubjectKind": {
      "enum": [
        "source_rights",
        "physical_provenance",
        "mechanism_truth",
        "review",
        "diagnostic_execution",
        "recovery_execution",
        "settled_outcome",
        "protocol_review",
        "shortcut_baseline",
        "control_suite",
        "model_visible_projection",
        "resource_usage",
        "truth_custody",
        "comparator_registry",
        "candidate_registry",
        "evidence_sequence",
        "admission_verifier_certificate"
      ],
      "title": "AttestationSubjectKind",
      "type": "string"
    },
    "EvidenceStreamSequence": {
      "additionalProperties": false,
      "properties": {
        "artifact_bytes": {
          "exclusiveMinimum": 0,
          "title": "Artifact Bytes",
          "type": "integer"
        },
        "artifact_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Artifact Sha256",
          "type": "string"
        },
        "chunk_bytes": {
          "exclusiveMinimum": 0,
          "maximum": 1048576,
          "title": "Chunk Bytes",
          "type": "integer"
        },
        "evidence_id": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
          "title": "Evidence Id",
          "type": "string"
        },
        "ordered_chunk_sha256": {
          "items": {
            "pattern": "^[0-9a-f]{64}$",
            "type": "string"
          },
          "minItems": 1,
          "title": "Ordered Chunk Sha256",
          "type": "array"
        },
        "source_order_monotonic": {
          "title": "Source Order Monotonic",
          "type": "boolean"
        }
      },
      "required": [
        "evidence_id",
        "artifact_sha256",
        "artifact_bytes",
        "chunk_bytes",
        "ordered_chunk_sha256",
        "source_order_monotonic"
      ],
      "title": "EvidenceStreamSequence",
      "type": "object"
    },
    "SignedAttestation": {
      "additionalProperties": false,
      "properties": {
        "attestation_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Attestation Hash",
          "type": "string"
        },
        "attestation_id": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
          "title": "Attestation Id",
          "type": "string"
        },
        "issued_at": {
          "format": "date-time",
          "title": "Issued At",
          "type": "string"
        },
        "schema_version": {
          "const": "fieldtrue.signed-attestation.v1",
          "default": "fieldtrue.signed-attestation.v1",
          "title": "Schema Version",
          "type": "string"
        },
        "signature": {
          "pattern": "^[0-9a-f]{128}$",
          "title": "Signature",
          "type": "string"
        },
        "signer_id": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
          "title": "Signer Id",
          "type": "string"
        },
        "signer_public_key": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Signer Public Key",
          "type": "string"
        },
        "subject_kind": {
          "$ref": "#/$defs/AttestationSubjectKind"
        },
        "subject_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Subject Sha256",
          "type": "string"
        }
      },
      "required": [
        "attestation_id",
        "signer_id",
        "subject_kind",
        "subject_sha256",
        "issued_at",
        "signer_public_key",
        "attestation_hash",
        "signature"
      ],
      "title": "SignedAttestation",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "attestation": {
      "$ref": "#/$defs/SignedAttestation"
    },
    "incident_id": {
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
      "title": "Incident Id",
      "type": "string"
    },
    "produced_at": {
      "format": "date-time",
      "title": "Produced At",
      "type": "string"
    },
    "receipt_id": {
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
      "title": "Receipt Id",
      "type": "string"
    },
    "schema_version": {
      "const": "fieldtrue.evidence-sequence-receipt.v1",
      "default": "fieldtrue.evidence-sequence-receipt.v1",
      "title": "Schema Version",
      "type": "string"
    },
    "source_steward_id": {
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
      "title": "Source Steward Id",
      "type": "string"
    },
    "streams": {
      "items": {
        "$ref": "#/$defs/EvidenceStreamSequence"
      },
      "minItems": 1,
      "title": "Streams",
      "type": "array"
    }
  },
  "required": [
    "receipt_id",
    "incident_id",
    "produced_at",
    "source_steward_id",
    "streams",
    "attestation"
  ],
  "title": "EvidenceSequenceReceipt",
  "type": "object"
}
