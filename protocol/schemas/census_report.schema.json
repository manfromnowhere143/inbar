{
  "$defs": {
    "CandidateScreening": {
      "additionalProperties": false,
      "description": "One screened source candidate. Never a scientific unit.",
      "properties": {
        "chronology": {
          "anyOf": [
            {
              "$ref": "#/$defs/ChronologyAssessment"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "domain_id": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
          "title": "Domain Id",
          "type": "string"
        },
        "gate_results": {
          "items": {
            "$ref": "#/$defs/GateResult"
          },
          "title": "Gate Results",
          "type": "array"
        },
        "object_class": {
          "$ref": "#/$defs/ObjectClass"
        },
        "role_inheritance": {
          "anyOf": [
            {
              "$ref": "#/$defs/RoleInheritanceAssessment"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "schema_version": {
          "const": "inbar.iter001.census-candidate-screening.v1",
          "default": "inbar.iter001.census-candidate-screening.v1",
          "title": "Schema Version",
          "type": "string"
        },
        "source_id": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
          "title": "Source Id",
          "type": "string"
        },
        "stratum": {
          "$ref": "#/$defs/Stratum"
        }
      },
      "required": [
        "source_id",
        "domain_id",
        "stratum",
        "object_class",
        "gate_results"
      ],
      "title": "CandidateScreening",
      "type": "object"
    },
    "CensusGate": {
      "enum": [
        "rights_and_terms",
        "immutable_version_or_authority_identifier",
        "physical_identity_and_system_family",
        "object_class_appropriate_evidence_presence",
        "mechanism_authority",
        "pre_outcome_ambiguity_and_chronology",
        "diagnostic_action_execution",
        "recovery_execution",
        "independent_settled_outcome",
        "clock_contract",
        "role_independence",
        "size_and_staging_feasibility"
      ],
      "title": "CensusGate",
      "type": "string"
    },
    "CensusVerdict": {
      "enum": [
        "CENSUS_QUALIFYING_CANDIDATE",
        "CENSUS_NULL_WITHIN_FRAME",
        "CENSUS_BLOCKED_RIGHTS",
        "CENSUS_INVALID",
        "CENSUS_INFRASTRUCTURE_NULL"
      ],
      "title": "CensusVerdict",
      "type": "string"
    },
    "ChronologyAssessment": {
      "additionalProperties": false,
      "description": "Conditions C1-C6 for a historical record to satisfy pre-outcome ambiguity.\n\nAll six are conjunctive. An exposed extraction (C6 false) is contaminated: it remains\npublishable as a diagnostic observation and is permanently ineligible for the\nthirty-incident floor. Counted historical dossiers therefore require a second,\nunexposed reviewer.",
      "properties": {
        "c1_hypothesis_artifact_content_frozen": {
          "title": "C1 Hypothesis Artifact Content Frozen",
          "type": "boolean"
        },
        "c2_date_established_by_publishing_authority": {
          "title": "C2 Date Established By Publishing Authority",
          "type": "boolean"
        },
        "c3_precedes_determination_artifact": {
          "title": "C3 Precedes Determination Artifact",
          "type": "boolean"
        },
        "c4_mechanism_set_stated_by_investigating_authority": {
          "title": "C4 Mechanism Set Stated By Investigating Authority",
          "type": "boolean"
        },
        "c5_explicit_unknown_category_present": {
          "title": "C5 Explicit Unknown Category Present",
          "type": "boolean"
        },
        "c6_extraction_reviewer_unexposed": {
          "title": "C6 Extraction Reviewer Unexposed",
          "type": "boolean"
        },
        "determination_artifact_locator": {
          "$ref": "#/$defs/SourceFactLocator"
        },
        "hypothesis_artifact_locator": {
          "$ref": "#/$defs/SourceFactLocator"
        },
        "schema_version": {
          "const": "inbar.iter001.census-chronology-assessment.v1",
          "default": "inbar.iter001.census-chronology-assessment.v1",
          "title": "Schema Version",
          "type": "string"
        }
      },
      "required": [
        "c1_hypothesis_artifact_content_frozen",
        "c2_date_established_by_publishing_authority",
        "c3_precedes_determination_artifact",
        "c4_mechanism_set_stated_by_investigating_authority",
        "c5_explicit_unknown_category_present",
        "c6_extraction_reviewer_unexposed",
        "hypothesis_artifact_locator",
        "determination_artifact_locator"
      ],
      "title": "ChronologyAssessment",
      "type": "object"
    },
    "FrozenIdentifierKind": {
      "enum": [
        "doi",
        "versioned_record",
        "tagged_release",
        "authority_assigned_docket_or_report_number",
        "independent_archival_snapshot_publishing_its_own_content_hash"
      ],
      "title": "FrozenIdentifierKind",
      "type": "string"
    },
    "GateResult": {
      "additionalProperties": false,
      "properties": {
        "gate": {
          "$ref": "#/$defs/CensusGate"
        },
        "rationale": {
          "minLength": 1,
          "title": "Rationale",
          "type": "string"
        },
        "schema_version": {
          "const": "inbar.iter001.census-gate-result.v1",
          "default": "inbar.iter001.census-gate-result.v1",
          "title": "Schema Version",
          "type": "string"
        },
        "status": {
          "$ref": "#/$defs/GateStatus"
        },
        "supporting_locators": {
          "default": [],
          "items": {
            "$ref": "#/$defs/SourceFactLocator"
          },
          "title": "Supporting Locators",
          "type": "array"
        }
      },
      "required": [
        "gate",
        "status",
        "rationale"
      ],
      "title": "GateResult",
      "type": "object"
    },
    "GateStatus": {
      "enum": [
        "passed",
        "failed",
        "not_screened"
      ],
      "title": "GateStatus",
      "type": "string"
    },
    "LocatorKind": {
      "enum": [
        "pdf_page",
        "section_path",
        "line_range",
        "record_field",
        "table_cell"
      ],
      "title": "LocatorKind",
      "type": "string"
    },
    "MutabilityClass": {
      "enum": [
        "content_frozen",
        "mutable_page"
      ],
      "title": "MutabilityClass",
      "type": "string"
    },
    "ObjectClass": {
      "enum": [
        "dataset_release",
        "investigation_record"
      ],
      "title": "ObjectClass",
      "type": "string"
    },
    "RoleInheritanceAssessment": {
      "additionalProperties": false,
      "description": "Conditions I1-I4 for inheriting a producing authority's role separation.\n\nThe frozen parent holds that organizational separation is supporting metadata and not\nproof by itself. These conditions do not weaken that; they define the narrow case in\nwhich inheritance is eligible at all.",
      "properties": {
        "governance_locator": {
          "$ref": "#/$defs/SourceFactLocator"
        },
        "i1_authority_governance_documents_role_separation": {
          "title": "I1 Authority Governance Documents Role Separation",
          "type": "boolean"
        },
        "i2_record_names_distinct_role_holders": {
          "title": "I2 Record Names Distinct Role Holders",
          "type": "boolean"
        },
        "i3_conflict_record_constructible": {
          "title": "I3 Conflict Record Constructible",
          "type": "boolean"
        },
        "i4_adjudicator_disjoint_from_operator_proposer_executor": {
          "title": "I4 Adjudicator Disjoint From Operator Proposer Executor",
          "type": "boolean"
        },
        "schema_version": {
          "const": "inbar.iter001.census-role-inheritance.v1",
          "default": "inbar.iter001.census-role-inheritance.v1",
          "title": "Schema Version",
          "type": "string"
        }
      },
      "required": [
        "i1_authority_governance_documents_role_separation",
        "i2_record_names_distinct_role_holders",
        "i3_conflict_record_constructible",
        "i4_adjudicator_disjoint_from_operator_proposer_executor",
        "governance_locator"
      ],
      "title": "RoleInheritanceAssessment",
      "type": "object"
    },
    "SourceFactLocator": {
      "additionalProperties": false,
      "description": "One factual assertion about a candidate, bound to exact retrieved bytes.\n\nA `mutable_page` fact can never establish a gate result. This is the frozen remedy for\nthe legacy screen, whose blocking facts rest on pages the mission does not control and\ntherefore cannot be re-checked by an independent auditor.",
      "properties": {
        "assertion_id": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
          "title": "Assertion Id",
          "type": "string"
        },
        "assertion_text": {
          "minLength": 1,
          "title": "Assertion Text",
          "type": "string"
        },
        "excerpt_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Excerpt Sha256",
          "type": "string"
        },
        "frozen_identifier_kind": {
          "anyOf": [
            {
              "$ref": "#/$defs/FrozenIdentifierKind"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "frozen_identifier_value": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Frozen Identifier Value"
        },
        "locator": {
          "$ref": "#/$defs/SourceLocator"
        },
        "mutability_class": {
          "$ref": "#/$defs/MutabilityClass"
        },
        "response_bytes": {
          "minimum": 0,
          "title": "Response Bytes",
          "type": "integer"
        },
        "response_bytes_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Response Bytes Sha256",
          "type": "string"
        },
        "retrieval_method": {
          "minLength": 1,
          "title": "Retrieval Method",
          "type": "string"
        },
        "retrieval_uri": {
          "minLength": 1,
          "title": "Retrieval Uri",
          "type": "string"
        },
        "retrieved_at": {
          "format": "date-time",
          "title": "Retrieved At",
          "type": "string"
        },
        "schema_version": {
          "const": "inbar.iter001.source-fact-locator.v1",
          "default": "inbar.iter001.source-fact-locator.v1",
          "title": "Schema Version",
          "type": "string"
        },
        "source_id": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
          "title": "Source Id",
          "type": "string"
        }
      },
      "required": [
        "assertion_id",
        "source_id",
        "assertion_text",
        "retrieval_uri",
        "retrieval_method",
        "retrieved_at",
        "response_bytes_sha256",
        "response_bytes",
        "locator",
        "excerpt_sha256",
        "mutability_class"
      ],
      "title": "SourceFactLocator",
      "type": "object"
    },
    "SourceLocator": {
      "additionalProperties": false,
      "properties": {
        "kind": {
          "$ref": "#/$defs/LocatorKind"
        },
        "value": {
          "minLength": 1,
          "title": "Value",
          "type": "string"
        }
      },
      "required": [
        "kind",
        "value"
      ],
      "title": "SourceLocator",
      "type": "object"
    },
    "Stratum": {
      "enum": [
        "prior_exposed",
        "prospective"
      ],
      "title": "Stratum",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "amendment_document_artifact_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Amendment Document Artifact Sha256",
      "type": "string"
    },
    "frame_declared_incomplete": {
      "const": true,
      "title": "Frame Declared Incomplete",
      "type": "boolean"
    },
    "frame_scope": {
      "minLength": 1,
      "title": "Frame Scope",
      "type": "string"
    },
    "iteration_id": {
      "const": "iter001_physical_causal_evidence_acquisition",
      "title": "Iteration Id",
      "type": "string"
    },
    "machine_proposal_artifact_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Machine Proposal Artifact Sha256",
      "type": "string"
    },
    "owner_approval_receipt_hash": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Owner Approval Receipt Hash",
      "type": "string"
    },
    "produced_at": {
      "format": "date-time",
      "title": "Produced At",
      "type": "string"
    },
    "schema_version": {
      "const": "inbar.iter001.census-report.v1",
      "default": "inbar.iter001.census-report.v1",
      "title": "Schema Version",
      "type": "string"
    },
    "screenings": {
      "items": {
        "$ref": "#/$defs/CandidateScreening"
      },
      "title": "Screenings",
      "type": "array"
    },
    "verdict": {
      "$ref": "#/$defs/CensusVerdict"
    }
  },
  "required": [
    "iteration_id",
    "amendment_document_artifact_sha256",
    "machine_proposal_artifact_sha256",
    "owner_approval_receipt_hash",
    "frame_scope",
    "frame_declared_incomplete",
    "screenings",
    "verdict",
    "produced_at"
  ],
  "title": "CensusReport",
  "type": "object"
}
