{
  "$defs": {
    "ArtifactBinding": {
      "additionalProperties": false,
      "properties": {
        "bytes": {
          "minimum": 0,
          "title": "Bytes",
          "type": "integer"
        },
        "media_type": {
          "minLength": 1,
          "title": "Media Type",
          "type": "string"
        },
        "path": {
          "minLength": 1,
          "title": "Path",
          "type": "string"
        },
        "sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Sha256",
          "type": "string"
        }
      },
      "required": [
        "path",
        "sha256",
        "bytes",
        "media_type"
      ],
      "title": "ArtifactBinding",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "compute_seconds": {
      "anyOf": [
        {
          "minimum": 0,
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Compute Seconds"
    },
    "diagnostic_action_cost_usd": {
      "anyOf": [
        {
          "pattern": "^(0|[1-9][0-9]*)(\\.[0-9]{1,6})?$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Diagnostic Action Cost Usd"
    },
    "diagnostic_test_seconds": {
      "anyOf": [
        {
          "minimum": 0,
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Diagnostic Test Seconds"
    },
    "downtime_seconds": {
      "anyOf": [
        {
          "minimum": 0,
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Downtime Seconds"
    },
    "engineering_seconds": {
      "anyOf": [
        {
          "minimum": 0,
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Engineering Seconds"
    },
    "incident_id": {
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
      "title": "Incident Id",
      "type": "string"
    },
    "measurement_artifact": {
      "$ref": "#/$defs/ArtifactBinding"
    },
    "realized_risk": {
      "anyOf": [
        {
          "maximum": 1.0,
          "minimum": 0.0,
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Realized Risk"
    },
    "recovery_action_cost_usd": {
      "anyOf": [
        {
          "pattern": "^(0|[1-9][0-9]*)(\\.[0-9]{1,6})?$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Recovery Action Cost Usd"
    },
    "recovery_seconds": {
      "anyOf": [
        {
          "minimum": 0,
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Recovery Seconds"
    },
    "schema_version": {
      "const": "fieldtrue.incident-resource-plane.v1",
      "default": "fieldtrue.incident-resource-plane.v1",
      "title": "Schema Version",
      "type": "string"
    }
  },
  "required": [
    "incident_id",
    "measurement_artifact"
  ],
  "title": "IncidentResourcePlane",
  "type": "object"
}
